class Solution {
    public int lengthOfLIS(int[] nums) {
        int dp[]=new int[nums.length];
        Arrays.fill(dp,1);
        int count=0,max=1;
        for(int i=1;i<nums.length;i++){
            count=1;
            for(int j=0;j<i;j++){
                if(nums[j]<nums[i]){
                  count=Math.max(dp[i]+dp[j],count);
                }
            }dp[i]=count;
        }
        for(int i:dp){
            max=Math.max(max,i);
        }return max;
    }
}
