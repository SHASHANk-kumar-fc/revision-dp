class Solution {
    public int maxProfit(int[] nums) {
        int n=nums.length;
        int dp[][]=new int[2][3];
        for(int i=n-1;i>=0;i--){
            for(int j=0;j<=1;j++){
               for(int cap=1;cap<=2;cap++){
                int profit=0;
        if(j==1){
          profit=Math.max(-nums[i]+dp[0][cap],dp[1][cap]);
        }else{
            profit=Math.max(nums[i]+dp[1][cap-1],dp[0][cap]);
        } dp[j][cap]=profit;
               }
            }
        }return dp[1][2];
    
}
     
    
}
