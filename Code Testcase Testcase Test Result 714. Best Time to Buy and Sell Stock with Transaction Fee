class Solution {
    public int maxProfit(int[] nums,int fee) {int n=nums.length;
      int dp[][]  =new int [n+1][2];
      for(int i=0;i<=n;i++)Arrays.fill(dp[i],-1);
      return rec(dp,nums,0,1,fee);
    }public static int rec(int [][]dp,int []nums,int i,int buy,int fee){
      if(i>=nums.length)return 0;
      if(dp[i][buy]!=-1)return dp[i][buy];
      int profit=0;
      if(buy==1){
       profit=Math.max(-nums[i]+rec(dp,nums,i+1,0,fee),rec(dp,nums,i+1,1,fee));
      }else 
      profit=Math.max(nums[i]-fee+rec(dp,nums,i+1,1,fee),rec(dp,nums,i+1,0,fee));
      return dp[i][buy]= profit;
    }
}
