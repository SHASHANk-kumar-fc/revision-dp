class Solution {
    public int maxProfit(int[] nums) {
        int dp[]=new int[2];
        for(int i=nums.length-1;i>=0;i--){
            
            for(int j=0;j<=1;j++){
               int profit=0;
             if(j==1){
          profit=Math.max(-nums[i]+dp[0],dp[1]);
        }else{
            profit=Math.max(nums[i]+dp[1],dp[0]);
        }  dp[j]=profit;  
            }
        }
      return dp[1]  ;
    }}
